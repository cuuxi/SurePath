@page
@model Cuuxi.SurePath.Backend.Pages.Users.IndexModel
@inject Cuuxi.SurePath.Backend.Services.TranslationService Translations
@{
    ViewData["Title"] = Translations.T("backend.users.title", "Brugere");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Translations.T("backend.users.title", "Brugere")</h2>
</div>

<table class="table table-hover table-striped">
    <thead class="table-dark">
        <tr>
            <th>@Translations.T("backend.users.col.id", "Id")</th>
            <th>@Translations.T("backend.users.col.name", "Navn")</th>
            <th>@Translations.T("backend.users.col.country", "Land")</th>
            <th>@Translations.T("backend.users.col.status", "Status")</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.FirstName @user.LastName</td>
                <td>@user.CountryCode</td>
                <td>
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">@Translations.T("backend.users.status.active", "Aktiv")</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Translations.T("backend.users.status.inactive", "Inaktiv")</span>
                    }
                </td>
                <td>
                    <a asp-page="/Users/Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">@Translations.T("backend.users.details", "Detaljer")</a>
                </td>
            </tr>
        }
    </tbody>
</table>
