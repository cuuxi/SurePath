@page "{key}"
@model Cuuxi.SurePath.Backend.Pages.Translations.EditModel
@inject Cuuxi.SurePath.Backend.Services.TranslationService Translations
@{
    ViewData["Title"] = $"Rediger: {Model.Key}";
}

<div class="mb-3">
    <a asp-page="/Translations/Index" class="btn btn-sm btn-outline-secondary">&larr; @Translations.T("backend.users.details.back", "Tilbage")</a>
</div>

<h4>
    <code>@Model.Key</code>
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <small class="text-muted fs-6 ms-2">@Model.Description</small>
    }
</h4>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success mt-3">@msg</div>
}

<form method="post" class="mt-4">
    <input type="hidden" asp-for="Key" />
    @for (int i = 0; i < Model.Languages.Count; i++)
    {
        var lang = Model.Languages[i];
        <div class="mb-4">
            <label class="form-label fw-bold">@lang.Name (@lang.Code)</label>
            <input type="hidden" name="Values[@i].LanguageCode" value="@lang.Code" />
            <textarea name="Values[@i].Value" class="form-control" rows="2">@Model.GetValue(lang.Code)</textarea>
        </div>
    }
    <button type="submit" class="btn btn-primary">@Translations.T("backend.translations.saveall", "Gem alle")</button>
</form>
