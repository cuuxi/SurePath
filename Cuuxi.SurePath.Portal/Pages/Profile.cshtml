@page
@model ProfileModel
@inject Cuuxi.SurePath.Portal.Services.TranslationService Translations
@{
    ViewData["Title"] = Translations.T("portal.profile.title", "Min profil");
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">@Translations.T("portal.profile.title", "Min profil")</h2>

        @if (TempData["Success"] is string msg)
        {
            <div class="alert alert-success">@msg</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label">@Translations.T("portal.profile.firstname", "Fornavn")</label>
                <input asp-for="FirstName" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">@Translations.T("portal.profile.lastname", "Efternavn")</label>
                <input asp-for="LastName" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">@Translations.T("portal.profile.country", "Land")</label>
                <select asp-for="CountryCode" class="form-select">
                    @foreach (var c in Model.Countries)
                    {
                        <option value="@c.Code">@c.Name</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">@Translations.T("portal.profile.save", "Gem ændringer")</button>
        </form>
    </div>
</div>
